#!/usr/bin/env bash
set -euo pipefail

WAL="$HOME/.cache/wal/colors.json"
THEME="$HOME/.local/share/vicinae/themes/wal.toml"

bg=$(jq -r '.special.background' "$WAL")
fg=$(jq -r '.special.foreground' "$WAL")
c0=$(jq -r '.colors.color0' "$WAL")
c1=$(jq -r '.colors.color1' "$WAL")
c2=$(jq -r '.colors.color2' "$WAL")
c3=$(jq -r '.colors.color3' "$WAL")
c4=$(jq -r '.colors.color4' "$WAL")
c5=$(jq -r '.colors.color5' "$WAL")
c6=$(jq -r '.colors.color6' "$WAL")
c8=$(jq -r '.colors.color8' "$WAL")

mkdir -p "$(dirname "$THEME")"

cat > "$THEME" <<EOF
[meta]
name = "wal"
description = "Generated from pywal"
variant = "dark"
inherits = "vicinae-dark"

[colors.core]
accent = "$c4"
accent_foreground = "$fg"
background = "$bg"
foreground = "$fg"
secondary_background = "$c0"
border = "$c8"

[colors.accents]
blue = "$c4"
green = "$c2"
magenta = "$c5"
orange = "$c3"
red = "$c1"
yellow = "$c3"
cyan = "$c6"
purple = "$c5"

[colors.text]
default = "$fg"
muted = "$c5"
danger = "$c1"
success = "$c2"
placeholder = "$c8"
selection = { background = "$c4", foreground = "$fg" }
EOF

vicinae theme set wal
